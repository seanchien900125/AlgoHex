{
  "name": "AlgoHex Dev",
  "build": {
    "context": "..",
    "dockerfile": "../docker/Dockerfile-dev"
  },
  "workspaceFolder": "/AlgoHex",
  "workspaceMount": "source=${localWorkspaceFolder},target=/AlgoHex,type=bind,consistency=cached",
  "containerEnv": {
    "CoinUtils_DIR": "/opt/coin-or",
    "IPOPT_HOME": "/opt/coin-or",
    "CBC_DIR": "/opt/coin-or",
    "CLP_DIR": "/opt/coin-or",
    "DISPLAY": "${localEnv:DISPLAY}"
  },
  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "cmake.buildDirectory": "${workspaceFolder}/build",
        "cmake.configureSettings": {
          "BONMIN_ROOT_DIR": "/opt/coin-or"
        }
      }
    }
  },
  "remoteUser": "root",
  "initializeCommand": "[ -n \"$DISPLAY\" ] && xhost +local:docker || true"
}
